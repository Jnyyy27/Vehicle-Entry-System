# Database Configuration
DB_HOST=your_rds_endpoint.us-east-1.rds.amazonaws.com
DB_USER=your_db_user
DB_PASSWORD=your_secure_password
DB_NAME=your_database_name

# AWS Cognito Configuration
COGNITO_DOMAIN=https://your-region-domain.auth.region.amazoncognito.com
COGNITO_USER_POOL_ID=region_PoolIdHere
CLIENT_ID=your_cognito_client_id
CLIENT_SECRET=your_cognito_client_secret

# Redirect URI (ngrok URL for local development)
# Get your ngrok URL by running: ngrok http 5000
REDIRECT_URI=https://your-ngrok-url.ngrok-free.dev/callback

# Flask Secret Key
SECRET_KEY=your_secret_key_for_flask

# Flask Configuration (optional)
# FLASK_ENV=development
# FLASK_DEBUG=True
